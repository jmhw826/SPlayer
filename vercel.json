{
  "rewrites": [
    {
      "source": "/:path",
      "destination": "/index.html"
    },
    {
      "source": "/ncmapi/:apiurl*",
      "destination": "${process.env.RENDERER_VITE_SERVER_URL}/:apiurl*"
    },
    {
      "source": "/unblock/:match*",
      "destination": "${process.env.VITE_UNM_API}:match*"
    }
  ]
}
