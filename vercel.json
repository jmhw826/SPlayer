{
  "rewrites": [
    {
      "source": "/:path",
      "destination": "/index.html"
    },
 {
      "source": "/api/:apiurl*",
      "destination": "${process.env.UNBLOCK_SERVER_URL}/:apiurl*"
 },
    {
      "source": "/unblock/:match*",
      "destination": "${process.env.UNBLOCK_SERVER_URL}:match*"
    }
  ]
}
